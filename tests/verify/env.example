# Configuration pour les tests de vérification ClipRace
# Copiez ce fichier vers .env et remplissez les valeurs

# URLs Supabase
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Clés Supabase
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Tokens d'authentification (générés automatiquement par le script)
BRAND_TOKEN=
CREATOR_TOKEN=
ADMIN_TOKEN=

# IDs de test (UUIDs fixes pour reproductibilité)
BRAND_ID=11111111-1111-1111-1111-111111111111
CREATOR_ID=22222222-2222-2222-2222-222222222222
ADMIN_ID=33333333-3333-3333-3333-333333333333
CONTEST_ID=44444444-4444-4444-4444-444444444444

# ID de soumission (généré dynamiquement)
SUBMISSION_ID=

# Configuration des tests
NODE_ENV=test
