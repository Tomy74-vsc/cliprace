{
  "testConfig": {
    "description": "Configuration pour les tests de vérification ClipRace",
    "version": "1.0.0",
    "environment": {
      "required": [
        "SUPABASE_URL",
        "SUPABASE_SERVICE_ROLE_KEY", 
        "SUPABASE_ANON_KEY",
        "NEXT_PUBLIC_SUPABASE_URL"
      ],
      "optional": [
        "NODE_ENV"
      ]
    },
    "testData": {
      "brandId": "11111111-1111-1111-1111-111111111111",
      "creatorId": "22222222-2222-2222-2222-222222222222", 
      "adminId": "33333333-3333-3333-3333-333333333333",
      "contestId": "44444444-4444-4444-4444-444444444444",
      "users": {
        "brand": {
          "email": "brand@test.local",
          "password": "Password123!",
          "role": "brand"
        },
        "creator": {
          "email": "creator@test.local", 
          "password": "Password123!",
          "role": "creator"
        },
        "admin": {
          "email": "admin@test.local",
          "password": "Password123!",
          "role": "admin"
        }
      },
      "testVideo": {
        "url": "https://www.youtube.com/watch?v=VIDEO123",
        "platform": "youtube",
        "videoId": "VIDEO123"
      }
    },
    "performance": {
      "thresholds": {
        "maxLatencyP95": 1000,
        "minSuccessRate": 95,
        "maxAvgLatency": 500
      },
      "iterations": {
        "submit": 10,
        "sign": 5,
        "database": 20
      }
    },
    "reports": {
      "outputDir": "tests/verify/results",
      "files": {
        "main": "report.md",
        "performance": "performance-report.md", 
        "final": "final-report.md"
      }
    },
    "cleanup": {
      "enabled": true,
      "afterTests": true,
      "onError": true
    }
  }
}
