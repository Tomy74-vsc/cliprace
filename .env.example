# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─── App ────────────────────────────────────────────────────────────────────
APP_URL=
NODE_ENV=

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Mode test: clés sk_test_* / pk_test_*
# Mode prod: clés sk_live_* / pk_live_*
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Webhook endpoint à enregistrer dans Stripe Dashboard:
# https://your-domain.com/api/payments/stripe/webhook
# Events requis: checkout.session.completed, payment_intent.payment_failed,
#                transfer.paid, account.updated

# ─── Métriques plateformes ──────────────────────────────────────────────────

# YouTube Data API v3
# Obtenir sur: https://console.cloud.google.com → APIs & Services → YouTube Data API v3
# Quota: 10 000 unités/jour (1 unité par videos.list)
YOUTUBE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# TikTok Research API
# Obtenir sur: https://developers.tiktok.com → Research API
# Nécessite: app approuvée Research API access
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
# Token d'accès Research API (long-lived, à renouveler)
TIKTOK_RESEARCH_ACCESS_TOKEN=

# Instagram Graph API
# Obtenir sur: https://developers.facebook.com → Mon App → Instagram Graph API
# Nécessite: compte Instagram Business/Creator lié à une Page Facebook
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# Token d'accès long-lived (60 jours, à renouveler via cron)
INSTAGRAM_ACCESS_TOKEN=

# ─── Cron sécurité ──────────────────────────────────────────────────────────
# Secret Vercel Cron — générer avec: openssl rand -hex 32
# À configurer aussi dans Vercel Dashboard → Settings → Environment Variables
# Les routes /api/cron/* vérifient: Authorization: Bearer CRON_SECRET
CRON_SECRET=

# ─── Admin MFA (TOTP) ───────────────────────────────────────────────────────
# ADMIN_MFA_REQUIRED: true en production (obligatoire pour /app/admin/*)
ADMIN_MFA_REQUIRED=true
# ADMIN_MFA_COOKIE_SECRET: HMAC secret — générer avec: openssl rand -hex 32
ADMIN_MFA_COOKIE_SECRET=
# ADMIN_MFA_ENCRYPTION_KEY: base64 de 32 bytes — générer avec:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_MFA_ENCRYPTION_KEY=

# ─── Admin RBAC ─────────────────────────────────────────────────────────────
# ADMIN_RBAC_REQUIRED: true en production (hard-fail si tables RBAC non seedées)
ADMIN_RBAC_REQUIRED=true
